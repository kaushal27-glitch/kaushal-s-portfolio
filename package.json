{
  "name": "kaushal-portfolio",
  "version": "1.0.0",
  "description": "Kaushal G's portfolio website - Full stack project with React frontend and Node.js backend",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "frontend:dev": "npm run dev --prefix ./insightstream-labs-main",
    "frontend:build": "npm run build --prefix ./insightstream-labs-main",
    "frontend:preview": "npm run preview --prefix ./insightstream-labs-main",
    "backend:dev": "npm run dev --prefix ./backend",
    "backend:start": "npm start --prefix ./backend",
    "setup": "npm ci --prefix ./backend && npm ci --prefix ./insightstream-labs-main"
  },
  "workspaces": [
    "backend",
    "insightstream-labs-main"
  ],
  "keywords": ["portfolio", "react", "vite", "typescript", "node"],
  "author": "Kaushal G",
  "license": "MIT"
}
